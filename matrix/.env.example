# Copy this file to infra/matrix/.env and fill in values.
#
# The first section is required for a normal deployment.

########################################
# Required
########################################

# Public Matrix URL served by this VPS. Must be HTTPS and no path.
MATRIX_BASE_URL=https://matrix.example.net

# Matrix server_name (MXID suffix @user:<server_name>).
# Use your base domain (not the matrix subdomain) and treat this as permanent.
# Changing it later requires a database wipe.
MATRIX_SERVER_NAME=example.net

# Cloudflare API token used for:
# 1) DNS upserts for matrix host
# 2) Traefik ACME DNS-01 challenge
# Required token permissions:
# - Zone -> DNS -> Edit
# - Zone -> Zone -> Read
# Scoped to your zone only.
CLOUDFLARE_API_TOKEN=__REPLACE_WITH_REAL_TOKEN__

# Registration policy (recommended: token-gated).
MATRIX_ALLOW_REGISTRATION=true
MATRIX_ALLOW_OPEN_REGISTRATION=false

# Required when MATRIX_ALLOW_REGISTRATION=true and MATRIX_ALLOW_OPEN_REGISTRATION=false.
# Generate with:
#   openssl rand -hex 32
MATRIX_REGISTRATION_TOKEN=__REPLACE_WITH_STRONG_RANDOM_TOKEN__

########################################
# Optional: Hetzner VPS Shape
########################################

# Resource name in Hetzner.
HCLOUD_SERVER_NAME=tuwunel-matrix

# Server type (list options: hcloud server-type list).
HCLOUD_SERVER_TYPE=cx23

# OS image (list options: hcloud image list -t system).
HCLOUD_SERVER_IMAGE=debian-12

# Preferred location (list options: hcloud location list).
HCLOUD_SERVER_LOCATION=nbg1

# Space-separated fallback locations if preferred has no capacity.
HCLOUD_SERVER_LOCATION_FALLBACKS=fsn1

########################################
# Optional: Network/Security
########################################

# Restrict SSH ingress to trusted CIDRs.
# Space-separated list.
# Example: HCLOUD_SSH_ALLOWED_NETS=203.0.113.42/32 2001:db8::/128
# Default is 0.0.0.0/0 if unset.
# HCLOUD_SSH_ALLOWED_NETS=203.0.113.42/32

# When true, port 80/443 firewall ingress is Cloudflare edge IPs only.
HCLOUD_HTTP_ALLOW_CLOUDFLARE_ONLY=true

# Disable only if you manage DNS yourself.
# CLOUDFLARE_MANAGE_DNS=true

# Keep proxied=true unless you intentionally want DNS-only records.
# CLOUDFLARE_DNS_PROXIED=true

# TTL 1 means "automatic" in Cloudflare API.
# CLOUDFLARE_DNS_TTL=1

########################################
# Optional: Matrix Behavior
########################################

# Keep guests disabled for private deployments.
# MATRIX_ALLOW_GUEST_REGISTRATION=false

# Federation off by default for single-family/private server.
# MATRIX_ALLOW_FEDERATION=false
# MATRIX_FEDERATE_CREATED_ROOMS=false
# MATRIX_FEDERATE_ADMIN_ROOM=false

# Encryption defaults.
# MATRIX_ALLOW_ENCRYPTION=true
# MATRIX_ENCRYPTION_DEFAULT_ROOM_TYPE=all

# Admin bootstrap behavior.
# MATRIX_GRANT_ADMIN_TO_FIRST_USER=true
# MATRIX_CREATE_ADMIN_ROOM=true

# Optional emergency password file source (leave empty unless needed).
# MATRIX_EMERGENCY_PASSWORD=

# Override well-known responses served by tuwunel (normally auto-derived).
# MATRIX_WELL_KNOWN_CLIENT_URL=https://matrix.example.net
# MATRIX_WELL_KNOWN_SERVER=matrix.example.net:443

########################################
# Optional: Runtime/Images
########################################

# TRAEFIK_IMAGE=traefik:v3
# TUWUNEL_IMAGE=ghcr.io/matrix-construct/tuwunel:latest
# MATRIX_DATA_ROOT=/srv/matrix

########################################
# Optional: Advanced Overrides
########################################

# CLOUDFLARE_ZONE_NAME defaults to MATRIX_SERVER_NAME.
# Override only for unusual delegated-zone setups.
# CLOUDFLARE_ZONE_NAME=example.net

# Defaults are ~/.ssh/id_ed25519(.pub). Override only if needed.
# HCLOUD_SSH_KEY_NAME=tuwunel-matrix-key
# HCLOUD_SSH_PUBLIC_KEY_PATH=/Users/you/.ssh/id_ed25519.pub
# HCLOUD_SSH_PRIVATE_KEY_PATH=/Users/you/.ssh/id_ed25519
# HCLOUD_SSH_KNOWN_HOSTS_FILE=/path/to/matrix_known_hosts
